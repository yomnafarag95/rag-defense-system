# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
.venv311/
venv/
env/
ENV/

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
secrets.json

# ── Large data files (not committed – use DVC or direct download) ────────────
data/
!data/.gitkeep

# ── Trained model weights (too large for GitHub) ─────────────────────────────
models/
!models/.gitkeep

# ── Log files ────────────────────────────────────────────────────────────────
logs/
!logs/.gitkeep
*.log

# ── Generated figures (reproducible from code) ───────────────────────────────
figures/
benchmark_figures/
*.png
*.pdf
*.eps

# ── LaTeX auxiliary files ─────────────────────────────────────────────────────
*.aux
*.bbl
*.blg
*.out
*.synctex.gz

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb
